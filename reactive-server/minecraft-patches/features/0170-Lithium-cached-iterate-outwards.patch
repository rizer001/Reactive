diff --git a/net/minecraft/core/BlockPos.java b/net/minecraft/core/BlockPos.java
index 97e890079a3b5277678c4f9cb1334a53646cb0e9..c4ca0e7caca04948682d99accd22d0d4443ca9d3 100644
--- a/net/minecraft/core/BlockPos.java
+++ b/net/minecraft/core/BlockPos.java
@@ -330,7 +330,18 @@ public class BlockPos extends Vec3i {
         };
     }
 
+    // JettPack start - lithium: cached iterate outwards
+    private static final org.dreeam.leaf.util.cache.IterateOutwardsCache ITERATE_OUTWARDS_CACHE = new org.dreeam.leaf.util.cache.IterateOutwardsCache(50);
+    private static final it.unimi.dsi.fastutil.longs.LongList HOGLIN_PIGLIN_CACHE = ITERATE_OUTWARDS_CACHE.getOrCompute(8, 4, 8);
+    // JettPack end - lithium: cached iterate outwards
+
     public static Iterable<BlockPos> withinManhattan(final BlockPos origin, final int reachX, final int reachY, final int reachZ) {
+        // JettPack start - lithium: cached iterate outwards
+        if (origin != org.dreeam.leaf.util.cache.IterateOutwardsCache.POS_ZERO) {
+            final it.unimi.dsi.fastutil.longs.LongList positions = reachX == 8 && reachY == 4 && reachZ == 8 ? HOGLIN_PIGLIN_CACHE : ITERATE_OUTWARDS_CACHE.getOrCompute(reachX, reachY, reachZ);
+            return new org.dreeam.leaf.util.cache.LongList2BlockPosMutableIterable(origin, positions);
+        }
+        // JettPack end - lithium: cached iterate outwards
         int maxDepth = reachX + reachY + reachZ;
         int originX = origin.getX();
         int originY = origin.getY();
