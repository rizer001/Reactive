+                        this.setDeltaMovement(Vec3.ZERO);
+                        this.discard(org.bukkit.event.entity.EntityRemoveEvent.Cause.DISCARD);
+                        return;
+                    }
+                }
+            }
+            // Leaf end - Prevent entity from moving into weak loaded chunks
             this.setPos(x, y, z);
         }
     }
