From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: HaHaWTH <102713261+HaHaWTH@users.noreply.github.com>
Date: Tue, 9 Nov 2077 00:00:00 +0800
Subject: [PATCH] Fix MC-270656

Related MC issue: https://bugs.mojang.com/browse/MC/issues/MC-270656

diff --git a/net/minecraft/server/level/ServerPlayer.java b/net/minecraft/server/level/ServerPlayer.java
index 91be1caf39dca3f4e1a1db6087513b31a468a40c..f6320f534137f33c3dc21e470bf6f427e207af6a 100644
--- a/net/minecraft/server/level/ServerPlayer.java
+++ b/net/minecraft/server/level/ServerPlayer.java
@@ -1078,6 +1078,7 @@ public class ServerPlayer extends Player implements ca.spottedleaf.moonrise.patc
     }
 
     public void trackStartFallingPosition() {
+        if (org.dreeam.leaf.config.modules.fixes.MCBugFix.mc270656) this.resetImpulseImpactIfNeeded(false); // Leaf - Fix MC-270656
         if (this.fallDistance > 0.0 && this.startingToFallPosition == null) {
             this.startingToFallPosition = this.position();
             if (this.currentExplosionImpactPos != null && this.currentExplosionImpactPos.y <= this.startingToFallPosition.y) {
@@ -1089,6 +1090,22 @@ public class ServerPlayer extends Player implements ca.spottedleaf.moonrise.patc
         }
     }
 
+    // Leaf start - Fix MC-270656
+    private void resetImpulseImpactIfNeeded(final boolean force) {
+        if (this.currentImpulseImpactPos == null) return;
+        if (this.currentExplosionCause == null || this.currentExplosionCause.getType() != EntityTypes.WIND_CHARGE) return;
+
+        if (force || this.getAbilities().flying
+            || this.isFallFlying()
+            || this.onClimbable()
+            || this.isPassenger()
+            || this.hasEffect(MobEffects.LEVITATION)) {
+            this.currentImpulseImpactPos = null;
+            this.currentExplosionCause = null;
+        }
+    }
+    // Leaf end - Fix MC-270656
+
     public void trackEnteredOrExitedLavaOnVehicle() {
         if (this.getVehicle() != null && this.getVehicle().isInLava()) {
             if (this.enteredLavaOnVehiclePosition == null) {
@@ -1576,6 +1593,7 @@ public class ServerPlayer extends Player implements ca.spottedleaf.moonrise.patc
             this.connection.internalTeleport(PositionMoveRotation.of(transition), transition.relatives()); // CraftBukkit
             this.connection.resetPosition();
             transition.postTeleportTransition().onTransition(this);
+            if (org.dreeam.leaf.config.modules.fixes.MCBugFix.mc270656) this.resetImpulseImpactIfNeeded(true); // Leaf - Fix MC-270656
             return this;
         }
 
@@ -1622,6 +1640,7 @@ public class ServerPlayer extends Player implements ca.spottedleaf.moonrise.patc
             this.stopUsingItem();
         }
         // Paper end - Reset shield blocking on dimension change
+        if (org.dreeam.leaf.config.modules.fixes.MCBugFix.mc270656) this.resetImpulseImpactIfNeeded(true); // Leaf - Fix MC-270656
         return this;
     }
 
