From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OverwriteMC <artyom030803@gmail.com>
Date: Tue, 31 Mar 2026 09:30:12 +0300
Subject: [PATCH] Skip VehicleEntityCollisionEvent if no listeners


diff --git a/net/minecraft/world/entity/vehicle/boat/AbstractBoat.java b/net/minecraft/world/entity/vehicle/boat/AbstractBoat.java
index 2e4ee279e4a9afacdfdfb6e1ed99a66c08aee4c9..ad7b39f3583e1ac56d2bbdf7f7fd70ad34e01042 100644
--- a/net/minecraft/world/entity/vehicle/boat/AbstractBoat.java
+++ b/net/minecraft/world/entity/vehicle/boat/AbstractBoat.java
@@ -188,7 +188,7 @@ public abstract class AbstractBoat extends VehicleEntity implements Leashable {
         if (entity instanceof AbstractBoat) {
             if (entity.getBoundingBox().minY < this.getBoundingBox().maxY) {
                 // CraftBukkit start
-                if (!this.isPassengerOfSameVehicle(entity)) {
+                if (!this.isPassengerOfSameVehicle(entity) && org.bukkit.event.vehicle.VehicleEntityCollisionEvent.getHandlerList().getRegisteredListeners().length > 0) { // Leaf - Skip VehicleEntityCollisionEvent if no listeners
                     org.bukkit.event.vehicle.VehicleEntityCollisionEvent event = new org.bukkit.event.vehicle.VehicleEntityCollisionEvent(
                         (org.bukkit.entity.Vehicle) this.getBukkitEntity(),
                         entity.getBukkitEntity()
@@ -200,7 +200,7 @@ public abstract class AbstractBoat extends VehicleEntity implements Leashable {
             }
         } else if (entity.getBoundingBox().minY <= this.getBoundingBox().minY) {
             // CraftBukkit start
-            if (!this.isPassengerOfSameVehicle(entity)) {
+            if (!this.isPassengerOfSameVehicle(entity) && org.bukkit.event.vehicle.VehicleEntityCollisionEvent.getHandlerList().getRegisteredListeners().length > 0) { // Leaf - Skip VehicleEntityCollisionEvent if no listeners
                 org.bukkit.event.vehicle.VehicleEntityCollisionEvent event = new org.bukkit.event.vehicle.VehicleEntityCollisionEvent(
                     (org.bukkit.entity.Vehicle) this.getBukkitEntity(),
                     entity.getBukkitEntity()
diff --git a/net/minecraft/world/entity/vehicle/minecart/AbstractMinecart.java b/net/minecraft/world/entity/vehicle/minecart/AbstractMinecart.java
index 9b2f1834f364b30a48ba13198af485e2bf8a1cd1..9e0cb1ee694f9d822a41f2a35754452e2cfd0219 100644
--- a/net/minecraft/world/entity/vehicle/minecart/AbstractMinecart.java
+++ b/net/minecraft/world/entity/vehicle/minecart/AbstractMinecart.java
@@ -187,6 +187,7 @@ public abstract class AbstractMinecart extends VehicleEntity {
             return false;
         }
 
+        if (org.bukkit.event.vehicle.VehicleEntityCollisionEvent.getHandlerList().getRegisteredListeners().length == 0) return true; // Leaf - Skip VehicleEntityCollisionEvent if no listeners
         org.bukkit.event.vehicle.VehicleEntityCollisionEvent collisionEvent = new org.bukkit.event.vehicle.VehicleEntityCollisionEvent((org.bukkit.entity.Vehicle) this.getBukkitEntity(), entity.getBukkitEntity());
         return collisionEvent.callEvent();
         // Paper end - fix VehicleEntityCollisionEvent not called when colliding with player
@@ -624,11 +625,13 @@ public abstract class AbstractMinecart extends VehicleEntity {
                 if (!this.level().paperConfig().collisions.allowVehicleCollisions && this.level().paperConfig().collisions.onlyPlayersCollide && !(entity instanceof Player)) return; // Paper - Collision option for requiring a player participant
                 if (!this.hasPassenger(entity)) {
                     // CraftBukkit start
+                    if (org.bukkit.event.vehicle.VehicleEntityCollisionEvent.getHandlerList().getRegisteredListeners().length > 0) { // Leaf - Skip VehicleEntityCollisionEvent if no listeners
                     org.bukkit.event.vehicle.VehicleEntityCollisionEvent collisionEvent = new org.bukkit.event.vehicle.VehicleEntityCollisionEvent(
                         (org.bukkit.entity.Vehicle) this.getBukkitEntity(),
                         entity.getBukkitEntity()
                     );
                     if (!collisionEvent.callEvent()) return;
+                    } // Leaf - Skip VehicleEntityCollisionEvent if no listeners
                     // CraftBukkit end
                     double xa = entity.getX() - this.getX();
                     double za = entity.getZ() - this.getZ();
