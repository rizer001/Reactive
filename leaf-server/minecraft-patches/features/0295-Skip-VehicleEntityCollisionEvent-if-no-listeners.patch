                         if (pickedUp) {
@@ -558,6 +561,7 @@ public class NewMinecartBehavior extends MinecartBehavior {
 
     public boolean pushEntities(final AABB hitbox) {
         boolean pushed = false;
+        final boolean hasVehicleEntityCollisionEvent = org.bukkit.event.vehicle.VehicleEntityCollisionEvent.getHandlerList().getRegisteredListeners().length > 0; // Leaf - Skip VehicleEntityCollisionEvent if no listeners
         if (this.minecart.isRideable()) {
             List<Entity> entities = this.level().getEntities(this.minecart, hitbox, EntitySelector.pushableBy(this.minecart));
             if (!entities.isEmpty()) {
@@ -568,7 +572,7 @@ public class NewMinecartBehavior extends MinecartBehavior {
                         || this.minecart.isVehicle()
                         || entity.isPassenger()) {
                         // CraftBukkit start
-                        if (!this.minecart.isPassengerOfSameVehicle(entity)) {
+                        if (!this.minecart.isPassengerOfSameVehicle(entity) && hasVehicleEntityCollisionEvent) { // Leaf - Skip VehicleEntityCollisionEvent if no listeners
                             org.bukkit.event.vehicle.VehicleEntityCollisionEvent collisionEvent = new org.bukkit.event.vehicle.VehicleEntityCollisionEvent(
                                 (org.bukkit.entity.Vehicle) this.minecart.getBukkitEntity(),
                                 entity.getBukkitEntity()
@@ -587,6 +591,7 @@ public class NewMinecartBehavior extends MinecartBehavior {
             for (Entity entity : this.level().getEntities(this.minecart, hitbox)) {
                 if (!this.minecart.hasPassenger(entity) && entity.isPushable() && entity instanceof AbstractMinecart) {
                     // CraftBukkit start
+                    if (hasVehicleEntityCollisionEvent) { // Leaf - Skip VehicleEntityCollisionEvent if no listeners
                     org.bukkit.event.vehicle.VehicleEntityCollisionEvent collisionEvent = new org.bukkit.event.vehicle.VehicleEntityCollisionEvent(
                         (org.bukkit.entity.Vehicle) this.minecart.getBukkitEntity(),
                         entity.getBukkitEntity()
@@ -594,6 +599,7 @@ public class NewMinecartBehavior extends MinecartBehavior {
                     if (!collisionEvent.callEvent()) {
                         continue;
                     }
+                    } // Leaf - Skip VehicleEntityCollisionEvent if no listeners
                     // CraftBukkit end
                     entity.push(this.minecart);
                     pushed = true;
